---
import { commentConfig } from "@/config/commentConfig";
import { url } from "@/utils/url-utils";

interface Props {
	path: string;
}

const config = {
	...commentConfig.twikoo,
	el: "#tcomment",
	path: Astro.props.path,
};

const isVisitorCountEnabled = commentConfig.twikoo?.visitorCount === true;
---

<div id="tcomment"></div>
<!-- 使用自编译的 Twikoo 文件，避免点赞等按钮导致页面触发滚动回顶部 https://github.com/twikoojs/twikoo/issues/721 -->
<script is:inline src={url("/assets/js/twikoo.nocss.js")}></script>
<link rel="stylesheet" href={url("/assets/css/twikoo.css")} />
<link rel="stylesheet" href={url("/assets/css/twikoo-custom.css")} />
<script is:inline define:vars={{ config, isVisitorCountEnabled }}>
  function getCurrentPath() {
    const pathname = window.location.pathname;
    return pathname.endsWith("/") && pathname.length > 1
      ? pathname.slice(0, -1)
      : pathname;
  }

  function createTwikooConfig() {
    return {
      ...config,
      path: getCurrentPath(),
      el: "#tcomment",
    };
  }

  async function fetchAndDisplayVisitorCount() {
    if (!isVisitorCountEnabled) return;

    const currentPath = getCurrentPath();
    const postIdMatch = currentPath.match(/\/posts\/([^/]+)$/);
    if (!postIdMatch) return;

    const postId = postIdMatch[1];

    try {
      const response = await fetch('/api/twikoo-stats.json');
      const data = await response.json();

      if (data.success && data.articles) {
        const article = data.articles.find(art => art.id === postId);
        const visitorEl = document.getElementById('twikoo_visitors');
        const errorEl = document.getElementById('twikoo_visitors_error');

        if (article) {
          if (article.views >= 0) {
            visitorEl.textContent = article.views.toLocaleString();
            if (errorEl) errorEl.style.display = 'none';
          } else {
            visitorEl.textContent = 'N/A';
            if (errorEl) {
              errorEl.style.display = 'inline';
              errorEl.textContent = article.error || '获取失败';
            }
          }
        }
      } else {
        const visitorEl = document.getElementById('twikoo_visitors');
        const errorEl = document.getElementById('twikoo_visitors_error');
        if (visitorEl) visitorEl.textContent = 'N/A';
        if (errorEl) {
          errorEl.style.display = 'inline';
          errorEl.textContent = data.error || '获取失败';
        }
        console.error('[Twikoo] 获取访问量失败:', data.error);
      }
    } catch (error) {
      const visitorEl = document.getElementById('twikoo_visitors');
      const errorEl = document.getElementById('twikoo_visitors_error');
      if (visitorEl) visitorEl.textContent = 'N/A';
      if (errorEl) {
        errorEl.style.display = 'inline';
        errorEl.textContent = `网络错误: ${error}`;
      }
      console.error('[Twikoo] 获取访问量网络错误:', error);
    }
  }

  function initTwikoo() {
    if (typeof twikoo !== "undefined") {
      const commentEl = document.getElementById("tcomment");
      if (commentEl) {
        commentEl.innerHTML = "";

        const dynamicConfig = createTwikooConfig();
        console.log("[Twikoo] 初始化配置:", dynamicConfig);

        twikoo
          .init(dynamicConfig)
          .then(() => {
            console.log("[Twikoo] 初始化完成");
          })
          .catch((error) => {
            console.error("[Twikoo] 初始化失败:", error);
          });
      }
    } else {
      setTimeout(initTwikoo, 500);
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    initTwikoo();
    if (isVisitorCountEnabled) {
      fetchAndDisplayVisitorCount();
    }
  });

  if (window.swup && window.swup.hooks) {
    window.swup.hooks.on("content:replace", function () {
      setTimeout(() => {
        initTwikoo();
        if (isVisitorCountEnabled) {
          fetchAndDisplayVisitorCount();
        }
      }, 200);
    });
  } else {
    document.addEventListener("swup:enable", function () {
      if (window.swup && window.swup.hooks) {
        window.swup.hooks.on("content:replace", function () {
          setTimeout(() => {
            initTwikoo();
            if (isVisitorCountEnabled) {
              fetchAndDisplayVisitorCount();
            }
          }, 200);
        });
      }
    });
  }

  document.addEventListener("firefly:page:loaded", function () {
    const commentEl = document.getElementById("tcomment");
    if (commentEl) {
      console.log("[Twikoo] 通过自定义事件重新初始化");
      initTwikoo();
      if (isVisitorCountEnabled) {
        fetchAndDisplayVisitorCount();
      }
    }
  });
</script>